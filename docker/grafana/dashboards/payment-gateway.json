{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "id": 1,
      "title": "Payment success rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(payments_total_total{status=\"SUCCESS\"}[5m])) / clamp_min(sum(rate(payments_total_total{status=~\"SUCCESS|FAILED\"}[5m])), 1)",
          "legendFormat": "success rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Provider latency (avg, by provider)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (provider) (rate(provider_latency_seconds_sum[5m])) / clamp_min(sum by (provider) (rate(provider_latency_seconds_count[5m])), 1)",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Webhook delivery rate (by status)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (status) (rate(webhooks_delivery_attempts_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Payment volume processed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (currency) (increase(payments_amount_sum_total[1h]))",
          "legendFormat": "{{currency}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["payment-gateway"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "title": "Payment Gateway Overview",
  "uid": "paygateway-overview",
  "version": 1
}
