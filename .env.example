# ====== Server ======
SERVER_PORT=8080

# ====== PostgreSQL ======
DB_URL=jdbc:postgresql://localhost:5432/paygateway
DB_USERNAME=paygateway
DB_PASSWORD=paygateway

# ====== Redis ======
REDIS_HOST=localhost
REDIS_PORT=6379

# ====== JWT ======
# Use a long (>= 64 byte) random string in production
JWT_SECRET=change-me-to-a-very-long-random-secret-value-at-least-64-bytes-long-0123456789
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000

# ====== Stripe ======
# Leave the *_dummy placeholders to run providers in SIMULATION mode (no live calls)
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy

# ====== Razorpay ======
RAZORPAY_KEY_ID=rzp_test_dummy
RAZORPAY_KEY_SECRET=rzp_secret_dummy
RAZORPAY_WEBHOOK_SECRET=rzp_whsec_dummy

# ====== Misc ======
# Public base URL used to build hosted checkout links + webhook URLs
WEBHOOK_BASE_URL=http://localhost:8080
